{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Solven Advisory",
  "version": "1.0.0",
  "description": "Design tokens for Solven Advisory. Source of truth: design/tokens.css",

  "color": {
    "primary": {
      "charcoal":    { "value": "#2A2A28", "comment": "Wordmark, body type" },
      "sage-deep":   { "value": "#6B8068", "comment": "Chevron on light, accents" },
      "sage":        { "value": "#8FA68A", "comment": "Chevron on dark" },
      "bone":        { "value": "#F4F2EB", "comment": "Default page background" }
    },
    "secondary": {
      "sage-pale":   { "value": "#C8D4C2", "comment": "Background washes" },
      "grey-mid":    { "value": "#6B6B68", "comment": "Secondary type, captions" },
      "grey-light":  { "value": "#A8A8A4", "comment": "Metadata" },
      "rule-grey":   { "value": "#D8D6CF", "comment": "Hairline dividers" }
    },
    "dark": {
      "charcoal-deep": { "value": "#1F2420", "comment": "Dark mode background" }
    }
  },

  "font": {
    "family": {
      "serif": { "value": "Georgia, 'Times New Roman', serif" },
      "sans":  { "value": "Calibri, 'Helvetica Neue', Helvetica, Arial, sans-serif" }
    },
    "size": {
      "xs":   { "value": "0.75rem",   "comment": "12px" },
      "sm":   { "value": "0.875rem",  "comment": "14px" },
      "base": { "value": "1.0625rem", "comment": "17px — body minimum" },
      "md":   { "value": "1.25rem",   "comment": "20px" },
      "lg":   { "value": "1.5rem",    "comment": "24px" },
      "xl":   { "value": "2rem",      "comment": "32px — H2" },
      "2xl":  { "value": "2.75rem",   "comment": "44px — H1" },
      "3xl":  { "value": "4rem",      "comment": "64px — hero" }
    },
    "tracking": {
      "tight":   { "value": "-0.01em" },
      "normal":  { "value": "0" },
      "wide":    { "value": "0.05em" },
      "wider":   { "value": "0.20em",  "comment": "H3 / section labels" },
      "widest":  { "value": "0.32em",  "comment": "ADVISORY designator" }
    },
    "leading": {
      "tight":  { "value": "1.15" },
      "snug":   { "value": "1.35" },
      "normal": { "value": "1.5" },
      "loose":  { "value": "1.7" }
    }
  },

  "space": {
    "xs":  { "value": "0.25rem" },
    "sm":  { "value": "0.5rem" },
    "md":  { "value": "1rem" },
    "lg":  { "value": "1.5rem" },
    "xl":  { "value": "2.5rem" },
    "2xl": { "value": "4rem" },
    "3xl": { "value": "6rem" },
    "4xl": { "value": "9rem" }
  },

  "container": {
    "narrow": { "value": "36rem" },
    "prose":  { "value": "44rem" },
    "wide":   { "value": "64rem" }
  },

  "radius": {
    "sm": { "value": "2px" },
    "md": { "value": "4px" }
  },

  "breakpoint": {
    "sm": { "value": "480px" },
    "md": { "value": "768px" },
    "lg": { "value": "1024px" },
    "xl": { "value": "1280px" }
  },

  "transition": {
    "fast": { "value": "120ms ease-out" },
    "slow": { "value": "320ms ease-out" }
  }
}
