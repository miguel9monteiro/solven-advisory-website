---
// src/layouts/Base.astro — reference layout for every page
// Drop-in template. Customise per-page via props.

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Solven Advisory — AI Strategy for Private Equity in Iberia",
  description = "Solven Advisory helps private equity firms in Iberia adopt AI without losing the analytical judgment that makes their work defensible.",
  ogImage = "/og-image.png",
} = Astro.props;

// Astro.site is unset until the production domain is configured in
// astro.config.mjs. Until then, fall back to the relative path so the
// layout doesn't throw and og:image still resolves locally.
const ogImageUrl = Astro.site
  ? new URL(ogImage, Astro.site).toString()
  : ogImage;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const navLinks = [
  { href: "/approach", label: "Approach" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

// Canonical URL — strips query strings and trailing slashes for the
// crawler-facing reference. Falls back to Astro.url when site is unset.
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString().replace(/\/$/, "") || Astro.site.toString().replace(/\/$/, "")
  : Astro.url.toString();

// Schema.org structured data. Uses @graph to declare three linked
// entity types — the firm (ProfessionalService), the site (WebSite),
// and the four service offerings (Service) — so Google can build a
// coherent entity graph for knowledge-panel eligibility, richer search
// results, and service-level ranking.
const siteUrl = "https://www.solvenadvisory.ai";
const orgId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;

const services = [
  {
    slug: "diligence-and-deal-flow",
    name: "Diligence & deal flow",
    description:
      "AI-assisted first-pass diligence, comparables and benchmarking pulls, data room synthesis, and sourcing screens — defensible at investment committee.",
    audience: "Private equity deal teams",
  },
  {
    slug: "portfolio-operations",
    name: "Portfolio operations",
    description:
      "Continuous KPI monitoring, board pack drafts, value-creation plan tracking, and portfolio-wide thematic synthesis for asset management teams.",
    audience: "Private equity portfolio teams",
  },
  {
    slug: "investor-relations-and-compliance",
    name: "Investor relations & compliance",
    description:
      "Multilingual LP letters, capital call narratives, and SFDR / CSRD / ESG reporting workflows with a full audit trail.",
    audience: "Private equity CFO and IR teams",
  },
  {
    slug: "knowledge-and-methodology",
    name: "Knowledge & methodology",
    description:
      "Internal memo and post-mortem ingestion, searchable institutional memory, workflow design, and analyst training in the AI-as-adversary methodology.",
    audience: "Private equity managing partners",
  },
];

const jsonLdGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": orgId,
      name: "Solven Advisory",
      alternateName: "Solven",
      description:
        "AI strategy consultancy for private equity firms in Iberia. Helps PE firms deploy AI inside analyst workflows without losing the analytical judgment that makes their work defensible.",
      url: siteUrl,
      logo: `${siteUrl}/og-image.png`,
      image: `${siteUrl}/og-image.png`,
      email: "hello@solvenadvisory.ai",
      sameAs: ["https://www.linkedin.com/company/solven-advisory"],
      founder: [
        {
          "@type": "Person",
          name: "Miguel Monteiro",
          sameAs: ["https://www.linkedin.com/in/miguel-monteiro-50a1ab163"],
        },
        {
          "@type": "Person",
          name: "Bruno Mota",
          sameAs: ["https://www.linkedin.com/in/bmota"],
        },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Lisbon",
        addressCountry: "PT",
      },
      areaServed: [
        { "@type": "Country", name: "Portugal" },
        { "@type": "Country", name: "Spain" },
      ],
      knowsAbout: [
        "Private equity",
        "Artificial intelligence",
        "AI strategy",
        "Investment workflows",
        "LP communications",
        "Due diligence",
        "Portfolio operations",
      ],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      name: "Solven Advisory",
      url: siteUrl,
      publisher: { "@id": orgId },
      inLanguage: "en",
    },
    ...services.map((s) => ({
      "@type": "Service",
      "@id": `${siteUrl}/#service-${s.slug}`,
      name: s.name,
      description: s.description,
      provider: { "@id": orgId },
      areaServed: [
        { "@type": "Country", name: "Portugal" },
        { "@type": "Country", name: "Spain" },
      ],
      audience: { "@type": "BusinessAudience", audienceType: s.audience },
      serviceType: "AI strategy consulting",
    })),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#F4F2EB" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={Astro.url} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Design tokens — must be loaded first -->
    <link rel="stylesheet" href="/design/tokens.css" />
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Schema.org structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="site-header">
      <a href="/" class="site-header-mark" aria-label="Solven Advisory home">
        <img
          src="/logos/03_solven_horizontal_lockup.svg"
          alt="Solven Advisory"
          width="380"
          height="70"
        />
      </a>
      <nav aria-label="Primary">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={path === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <img
        src="/logos/02_solven_reversed_lockup.svg"
        alt="Solven Advisory"
        width="240"
        height="64"
      />
      <p class="footer-meta">
        Lisbon · {new Date().getFullYear()}
      </p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-lg) var(--space-2xl);
    border-bottom: var(--rule-thin);
  }

  .site-header nav {
    display: flex;
    gap: var(--space-xl);
  }

  .site-header-mark {
    line-height: 0;
  }

  .site-header nav a {
    text-decoration: none;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .site-header nav a:hover {
    color: var(--color-text);
  }

  .site-header nav a[aria-current="page"] {
    color: var(--color-text);
  }

  main {
    min-height: 70vh;
    padding: var(--space-3xl) var(--space-2xl);
  }

  .site-footer {
    background-color: var(--color-bg-dark);
    padding: var(--space-2xl);
    text-align: center;
  }

  .footer-meta {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .site-header {
      padding: var(--space-md) var(--space-lg);
      flex-direction: column;
      gap: var(--space-md);
    }
    main {
      padding: var(--space-2xl) var(--space-lg);
    }
  }
</style>
