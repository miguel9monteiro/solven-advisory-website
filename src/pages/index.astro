---
// src/pages/index.astro — homepage
// Hero (wordmark + one sentence + contact link) above the fold, then a short
// "Two ways we work" overview that routes detail to /services. The home page
// stays calm: one section below the hero, not the full offering.

import Base from "../layouts/Base.astro";

interface Offering {
  label: string;
  title: string;
  body: string;
  href: string;
  cta: string;
}

const offerings: Offering[] = [
  {
    label: "Enablement",
    title: "We teach the team to use Claude well.",
    body:
      "Hands-on sessions for every level of the firm, from analyst to partner, on your own workflows and the full Claude toolkit.",
    href: "/services#enablement",
    cta: "How we teach",
  },
  {
    label: "Delivery",
    title: "We build alongside you on the work itself.",
    body:
      "Diligence, portfolio operations, and investor relations, plus the methodology that decides where AI is used and where it isn't.",
    href: "/services#delivery",
    cta: "Where we work",
  },
  {
    label: "AI diligence",
    title: "We test whether the AI is real.",
    body:
      "When a company pitches itself as AI-native, we sit in and tell you whether the technology and the business model hold up, or whether it's a story.",
    href: "/services#diligence",
    cta: "What we examine",
  },
];
---

<Base
  title="Solven Advisory — AI Strategy for Private Equity in Iberia"
  description="Solven Advisory helps private equity firms in Iberia adopt AI without losing the analytical judgment that makes their work defensible."
>
  <section class="hero">
    <h1 class="hero-mark">
      <img
        src="/logos/01_solven_primary_lockup.svg"
        alt=""
        width="520"
        height="139"
        role="presentation"
      />
      <span class="visually-hidden">
        Solven Advisory — AI for private equity in Iberia
      </span>
    </h1>

    <p class="hero-statement">
      Solven Advisory helps private equity firms in Iberia adopt AI without
      losing the analytical judgment that makes their work defensible.
    </p>

    <a href="/contact" class="hero-cta">
      Get in touch
    </a>
  </section>

  <section class="ways" aria-labelledby="ways-title">
    <header class="ways-header">
      <h2 id="ways-title">How we work with your firm.</h2>
      <p class="lead">
        Enablement, delivery, and diligence. Three engagements, each designed to
        <a href="/approach">sharpen judgment, not substitute for it</a>.
      </p>
    </header>

    <div class="ways-grid">
      {offerings.map((o) => (
        <article class="way">
          <p class="designator">{o.label}</p>
          <h3 class="way-title">{o.title}</h3>
          <p class="way-body">{o.body}</p>
          <a href={o.href} class="way-link">{o.cta}</a>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    max-width: var(--container-narrow);
    margin: 0 auto;
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .hero-mark {
    margin: 0 0 var(--space-2xl);
    line-height: 0;
  }

  .hero-mark img {
    margin: 0 auto;
  }

  .hero-statement {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin: 0 auto var(--space-xl);
    max-width: 42ch;
  }

  .hero-cta {
    display: inline-block;
    text-decoration: none;
    font-size: var(--text-sm);
    color: var(--color-text);
    padding: var(--space-md) var(--space-xl);
    border: var(--rule-thin);
    border-color: var(--charcoal);
    transition: all var(--transition-fast);
  }

  .hero-cta:hover {
    background-color: var(--charcoal);
    color: var(--color-bg);
  }

  /* ----- Two ways we work ----- */
  .ways {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-2xl) 0 0;
  }

  .ways-header {
    margin: 0 0 var(--space-3xl);
  }

  .ways-header h2 {
    margin-bottom: var(--space-md);
  }

  .ways-header .lead {
    margin: 0;
    max-width: 46ch;
  }

  .ways-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-2xl) var(--space-xl);
  }

  .way {
    padding-top: var(--space-md);
    border-top: var(--rule-thin);
  }

  .way .designator {
    margin: 0 0 var(--space-lg);
  }

  /* Georgia subhead — override the default tracked-uppercase h3 treatment. */
  .way-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-md);
  }

  .way-body {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-lg);
  }

  .way-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--color-text);
    border-bottom: var(--rule-thin);
    border-color: var(--charcoal);
    padding-bottom: var(--space-xs);
  }

  @media (max-width: 768px) {
    .ways-header {
      margin-bottom: var(--space-2xl);
    }

    .ways-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
